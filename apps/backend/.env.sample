AWS_ACCESS_KEY_ID=
AWS_BUCKET_REGION=
AWS_SECRET_ACCESS_KEY=
# Secret used to sign JWTs (devise-jwt). Falls back to secret_key_base if unset.
DEVISE_JWT_SECRET_KEY=
# JWT lifetime in hours (default 24).
DEVISE_JWT_EXPIRATION_HOURS=24
# Comma-separated list of allowed CORS origins (default "*").
# The Vite dev server runs on http://localhost:5173.
CORS_ORIGINS=http://localhost:5173
DOCKER_ENABLED=false
NEW_RELIC_API_KEY=api_key
NEW_RELIC_APP_NAME='rails_api_base - development'
PASSWORD_RESET_URL=http://127.0.0.1:3000
SENDGRID_API_KEY=
SERVER_HOST=localhost
S3_BUCKET_NAME=
SWAGGER_USERNAME=username
SWAGGER_PASSWORD=password
CHAOTIC_ORDER=true
